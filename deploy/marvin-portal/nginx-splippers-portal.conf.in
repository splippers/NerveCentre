# Splippers unified portal (NerveCentre) — nginx site on port 80.
# Generated by install-portal.sh — placeholders @@BRICKWISE_PORT@@, @@ARCHIVE_PORT@@, @@SIC_PORT@@.
#
# Requires: nginx with gzip disabled for /brickwise/ so sub_filter can rewrite HTML (Accept-Encoding "").

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    root /var/www/splippers-portal;
    index index.html;

    location = / {
        try_files /index.html =404;
    }

    location = /brickwise {
        return 301 http://$host/brickwise/;
    }

    # Brickwise (Flask): strip /brickwise/ prefix when forwarding; rewrite /api paths in HTML for the browser.
    location /brickwise/ {
        proxy_pass http://127.0.0.1:@@BRICKWISE_PORT@@/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
        proxy_set_header Accept-Encoding "";

        sub_filter_types text/html;
        sub_filter_once off;
        sub_filter '"/api/' '"/brickwise/api/';
        sub_filter "'/api/" "'/brickwise/api/";
    }

    # Splippers Archive (FastAPI + static UI) — absolute asset paths; redirect to dedicated port.
    location = /archive {
        return 302 http://$host:@@ARCHIVE_PORT@@/;
    }
    location /archive/ {
        return 302 http://$host:@@ARCHIVE_PORT@@/;
    }

    # SIC / massdeb8 arena — redirect to dedicated port.
    location = /sic {
        return 302 http://$host:@@SIC_PORT@@/;
    }
    location /sic/ {
        return 302 http://$host:@@SIC_PORT@@/;
    }
}
